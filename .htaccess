# ============================================================
#  SJ Webdev Services — Apache config (Bluehost)
# ============================================================

# Serve index.html as the default page; hide directory listings
DirectoryIndex index.html
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS + non-www (apex) ONLY for the live domain.
  # This is scoped to sjwebdevservices.com so it does NOT interfere with
  # Bluehost's temporary preview URL — the temp link stays viewable
  # before DNS points to the account.
  RewriteCond %{HTTP_HOST} ^(www\.)?sjwebdevservices\.com$ [NC]
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.sjwebdevservices\.com$ [NC]
  RewriteRule ^(.*)$ https://sjwebdevservices.com/$1 [L,R=301]
</IfModule>

# Branded 404 page
ErrorDocument 404 /404.html

# Static asset caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css            "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/png           "access plus 1 month"
  ExpiresByType image/jpeg          "access plus 1 month"
  ExpiresByType image/svg+xml       "access plus 1 month"
  ExpiresByType image/x-icon        "access plus 1 month"
  ExpiresByType text/html           "access plus 0 seconds"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>
